@using taskplan_calendar.ViewModel
@model CalendarViewModel

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Calendar";
    Layout = "~/Views/Shared/_MenuLayout.cshtml";
}

@section Head {
    <link rel="stylesheet" href="~/css/calendar.css">
}

<div class="calendar-container">
    <!-- Sidebar Navigation -->
    <div class="calendar-sidebar">
        <div class="sidebar-nav">
            <a href="/" class="sidebar-btn">🏠 Home</a>
            <a href="/calendar" class="sidebar-btn active">📅 Calendar</a>
            <a href="/todos" class="sidebar-btn">✅ To-Dos</a>
            <a href="/categories" class="sidebar-btn">🏷️ Categories</a>
        </div>
    </div>

    <!-- Main Calendar -->
    <div class="calendar-main">
        <!-- Top Navigation Bar -->
        <div class="calendar-topbar">
            <div class="calendar-navigation">
                <button class="btn btn-sm btn-outline-primary" id="prevBtn">← Previous</button>
                <span id="viewLabel">@Model.GetViewLabel()</span>
                <button class="btn btn-sm btn-outline-primary" id="nextBtn">Next →</button>
            </div>

            <div class="calendar-actions">
                <div class="view-switcher">
                    <button class="view-btn @(Model.ViewType == "daily" ? "active" : "")" data-view="daily">Daily</button>
                    <button class="view-btn @(Model.ViewType == "weekly" ? "active" : "")" data-view="weekly">Weekly</button>
                    <button class="view-btn @(Model.ViewType == "monthly" ? "active" : "")" data-view="monthly">Monthly</button>
                </div>
                <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#addEventModal">
                    + Add Event
                </button>
            </div>
        </div>

        <!-- Calendar Content Area -->
        <div class="calendar-content">
            <div id="calendarView" class="calendar-loading">
                <p class="text-muted">Loading calendar...</p>
            </div>
        </div>
    </div>
</div>

<!-- Add Event Modal -->
<div class="modal fade" id="addEventModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Add Event</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="addEventForm">
                <div class="modal-body">
                    <!-- Basic Event Info -->
                    <div class="mb-3">
                        <label for="eventTitle" class="form-label">Event Title *</label>
                        <input type="text" class="form-control" id="eventTitle" name="title" required maxlength="200">
                    </div>

                    <div class="mb-3">
                        <label for="eventDescription" class="form-label">Description</label>
                        <textarea class="form-control" id="eventDescription" name="description" rows="3" maxlength="1000"></textarea>
                    </div>

                    <!-- Date & Time -->
                    <div class="row">
                        <div class="col-md-6">
                            <label for="eventStart" class="form-label">Start Date/Time *</label>
                            <input type="datetime-local" class="form-control" id="eventStart" name="startDateTime" required>
                        </div>
                        <div class="col-md-6">
                            <label for="eventEnd" class="form-label">End Date/Time *</label>
                            <input type="datetime-local" class="form-control" id="eventEnd" name="endDateTime" required>
                        </div>
                    </div>

                    <div class="form-check my-3">
                        <input type="checkbox" class="form-check-input" id="eventAllDay" name="isAllDay">
                        <label class="form-check-label" for="eventAllDay">All Day Event</label>
                    </div>

                    <!-- Category & Color -->
                    <div class="row">
                        <div class="col-md-6">
                            <label for="eventCategory" class="form-label">Category</label>
                            <select class="form-select" id="eventCategory" name="categoryId">
                                <option value="">-- No Category --</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label for="eventColor" class="form-label">Event Color</label>
                            <input type="color" class="form-control form-control-color" id="eventColor" name="colorHex" value="#007bff">
                        </div>
                    </div>

                    <hr class="my-4">
                    <h6>Recurrence (Optional)</h6>

                    <!-- Recurrence Pattern -->
                    <div class="mb-3">
                        <label for="recurrencePattern" class="form-label">Repeat</label>
                        <select class="form-select" id="recurrencePattern" name="recurrencePattern">
                            <option value="None">No Recurrence</option>
                            <option value="Daily">Daily</option>
                            <option value="Weekly">Weekly</option>
                            <option value="Monthly">Monthly</option>
                            <option value="Yearly">Yearly</option>
                        </select>
                    </div>

                    <!-- Weekly Options -->
                    <div id="weeklyOptions" style="display: none;">
                        <label class="form-label">Repeat on Days:</label>
                        <div class="form-check">
                            <input type="checkbox" class="form-check-input weekly-day" id="sunday" value="0">
                            <label class="form-check-label" for="sunday">Sunday</label>
                        </div>
                        <div class="form-check">
                            <input type="checkbox" class="form-check-input weekly-day" id="monday" value="1">
                            <label class="form-check-label" for="monday">Monday</label>
                        </div>
                        <div class="form-check">
                            <input type="checkbox" class="form-check-input weekly-day" id="tuesday" value="2">
                            <label class="form-check-label" for="tuesday">Tuesday</label>
                        </div>
                        <div class="form-check">
                            <input type="checkbox" class="form-check-input weekly-day" id="wednesday" value="3">
                            <label class="form-check-label" for="wednesday">Wednesday</label>
                        </div>
                        <div class="form-check">
                            <input type="checkbox" class="form-check-input weekly-day" id="thursday" value="4">
                            <label class="form-check-label" for="thursday">Thursday</label>
                        </div>
                        <div class="form-check">
                            <input type="checkbox" class="form-check-input weekly-day" id="friday" value="5">
                            <label class="form-check-label" for="friday">Friday</label>
                        </div>
                        <div class="form-check">
                            <input type="checkbox" class="form-check-input weekly-day" id="saturday" value="6">
                            <label class="form-check-label" for="saturday">Saturday</label>
                        </div>
                    </div>

                    <!-- Monthly Options -->
                    <div id="monthlyOptions" style="display: none;">
                        <label for="monthlyDay" class="form-label">Day of Month (1-31)</label>
                        <input type="number" class="form-control" id="monthlyDay" name="monthlyRecurrenceDay" min="1" max="31">
                    </div>

                    <!-- Recurrence End Date -->
                    <div class="mb-3 mt-3">
                        <label for="recurrenceEnd" class="form-label">End Recurrence (Optional)</label>
                        <input type="date" class="form-control" id="recurrenceEnd" name="recurrenceEndDate">
                        <small class="text-muted">Leave empty for indefinite recurrence</small>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Create Event</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Event Modal -->
<div class="modal fade" id="editEventModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Edit Event</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="editEventForm">
                <input type="hidden" id="editEventId">
                <div class="modal-body">
                    <!-- Basic Event Info -->
                    <div class="mb-3">
                        <label for="editEventTitle" class="form-label">Event Title *</label>
                        <input type="text" class="form-control" id="editEventTitle" name="title" required maxlength="200">
                    </div>

                    <div class="mb-3">
                        <label for="editEventDescription" class="form-label">Description</label>
                        <textarea class="form-control" id="editEventDescription" name="description" rows="3" maxlength="1000"></textarea>
                    </div>

                    <!-- Date & Time -->
                    <div class="row">
                        <div class="col-md-6">
                            <label for="editEventStart" class="form-label">Start Date/Time *</label>
                            <input type="datetime-local" class="form-control" id="editEventStart" name="startDateTime" required>
                        </div>
                        <div class="col-md-6">
                            <label for="editEventEnd" class="form-label">End Date/Time *</label>
                            <input type="datetime-local" class="form-control" id="editEventEnd" name="endDateTime" required>
                        </div>
                    </div>

                    <div class="form-check my-3">
                        <input type="checkbox" class="form-check-input" id="editEventAllDay" name="isAllDay">
                        <label class="form-check-label" for="editEventAllDay">All Day Event</label>
                    </div>

                    <!-- Category & Color -->
                    <div class="row">
                        <div class="col-md-6">
                            <label for="editEventCategory" class="form-label">Category</label>
                            <select class="form-select" id="editEventCategory" name="categoryId">
                                <option value="">-- No Category --</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label for="editEventColor" class="form-label">Event Color</label>
                            <input type="color" class="form-control form-control-color" id="editEventColor" name="colorHex">
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-danger" id="deleteEventBtn">Delete</button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Appointment Modal -->
<div class="modal fade" id="appointmentModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="appointmentModalTitle">New Appointment</h5>
                <button type="button" class="close" data-dismiss="modal">
                    <span>&times;</span>
                </button>
            </div>
            <form id="appointmentForm">
                <div class="modal-body">
                    <div class="form-group">
                        <label for="title">Title *</label>
                        <input type="text" class="form-control" id="title" name="title" required>
                    </div>
                    <div class="form-group">
                        <label for="description">Description</label>
                        <textarea class="form-control" id="description" name="description" rows="3"></textarea>
                    </div>
                    <div class="form-row">
                        <div class="form-group col-md-6">
                            <label for="startTime">Start Time *</label>
                            <input type="datetime-local" class="form-control" id="startTime" name="startTime" required>
                        </div>
                        <div class="form-group col-md-6">
                            <label for="endTime">End Time *</label>
                            <input type="datetime-local" class="form-control" id="endTime" name="endTime" required>
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="categoryId">Category</label>
                        <select class="form-control" id="categoryId" name="categoryId">
                            <option value="">No Category</option>
                        </select>
                    </div>
                    <div class="form-check">
                        <input type="checkbox" class="form-check-input" id="isRecurring" name="isRecurring">
                        <label class="form-check-label" for="isRecurring">
                            Recurring
                        </label>
                    </div>
                    <div id="recurringSection" style="display: none; margin-top: 15px; padding: 15px; border-left: 3px solid #007bff;">
                        <div class="form-group">
                            <label for="recurrencePattern">Pattern *</label>
                            <select class="form-control" id="recurrencePattern" name="recurrencePattern">
                                <option value="daily">Daily</option>
                                <option value="weekly">Weekly</option>
                                <option value="monthly">Monthly</option>
                                <option value="yearly">Yearly</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label for="recurrenceEndDate">End Date (leave empty for no end date)</label>
                            <input type="date" class="form-control" id="recurrenceEndDate" name="recurrenceEndDate">
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-danger" id="deleteBtn" style="display: none;">Delete</button>
                    <button type="submit" class="btn btn-primary">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/calendar.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.10/index.global.min.js"></script>
    <script>
        let currentEditingId = null;
        let currentStartTime = null;
        let currentEndTime = null;

        document.addEventListener('DOMContentLoaded', function() {
            const calendarEl = document.getElementById('calendar');
            const appointmentsData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Appointments));
            
            const events = appointmentsData.map(a => ({
                id: a.id,
                title: a.title,
                start: a.startTime,
                end: a.endTime,
                description: a.description,
                backgroundColor: a.categoryColor || '#007bff',
                borderColor: a.categoryColor || '#0056b3',
                extendedProps: {
                    categoryName: a.categoryName,
                    isRecurring: a.isRecurring,
                    recurrencePattern: a.recurrencePattern
                }
            }));

            const calendar = new FullCalendar.Calendar(calendarEl, {
                initialView: '@Model.ViewType' || 'dayGridMonth',
                initialDate: '@Model.ViewDate.ToString("yyyy-MM-dd")',
                headerToolbar: false,
                height: 'auto',
                contentHeight: 'auto',
                events: events,
                selectable: true,
                select: function(arg) {
                    openAddEventModal(arg.start, arg.end);
                },
                eventClick: function(arg) {
                    openEditEventModal(arg.event.id, arg.event);
                },
                eventDidMount: function(info) {
                    if(info.event.extendedProps.isRecurring) {
                        info.el.classList.add('recurring-event');
                    }
                }
            });

            calendar.render();

            // View switching
            document.querySelectorAll('.view-toggle').forEach(btn => {
                btn.addEventListener('click', function() {
                    const view = this.dataset.view;
                    calendar.changeView(view);
                    document.querySelectorAll('.view-toggle').forEach(b => {
                        b.classList.remove('btn-primary');
                        b.classList.add('btn-outline-primary');
                    });
                    this.classList.remove('btn-outline-primary');
                    this.classList.add('btn-primary');
                });
            });

            // Add event button
            document.getElementById('addEventBtn').addEventListener('click', function() {
                openAddEventModal(new Date(), new Date(new Date().getTime() + 60*60*1000));
            });

            // Form submission
            document.getElementById('appointmentForm').addEventListener('submit', function(e) {
                e.preventDefault();
                saveAppointment();
            });

            // Recurring checkbox toggle
            document.getElementById('isRecurring').addEventListener('change', function() {
                document.getElementById('recurringSection').style.display = this.checked ? 'block' : 'none';
            });

            // Delete button
            document.getElementById('deleteBtn').addEventListener('click', function() {
                if(currentEditingId && confirm('Are you sure you want to delete this appointment?')) {
                    deleteAppointment(currentEditingId);
                }
            });
        });

        function openAddEventModal(start, end) {
            currentEditingId = null;
            currentStartTime = start;
            currentEndTime = end;
            
            document.getElementById('appointmentForm').reset();
            document.getElementById('appointmentModalTitle').textContent = 'New Appointment';
            document.getElementById('deleteBtn').style.display = 'none';
            document.getElementById('recurringSection').style.display = 'none';
            
            const formatDateTime = (date) => {
                const d = new Date(date);
                const month = String(d.getMonth() + 1).padStart(2, '0');
                const day = String(d.getDate()).padStart(2, '0');
                const hours = String(d.getHours()).padStart(2, '0');
                const minutes = String(d.getMinutes()).padStart(2, '0');
                return `${d.getFullYear()}-${month}-${day}T${hours}:${minutes}`;
            };
            
            document.getElementById('startTime').value = formatDateTime(start);
            document.getElementById('endTime').value = formatDateTime(end);
            
            $('#appointmentModal').modal('show');
        }

        function openEditEventModal(id, event) {
            currentEditingId = id;
            document.getElementById('appointmentModalTitle').textContent = 'Edit Appointment';
            document.getElementById('deleteBtn').style.display = 'block';
            
            const formatDateTime = (dateStr) => {
                const d = new Date(dateStr);
                const month = String(d.getMonth() + 1).padStart(2, '0');
                const day = String(d.getDate()).padStart(2, '0');
                const hours = String(d.getHours()).padStart(2, '0');
                const minutes = String(d.getMinutes()).padStart(2, '0');
                return `${d.getFullYear()}-${month}-${day}T${hours}:${minutes}`;
            };
            
            document.getElementById('title').value = event.title || '';
            document.getElementById('description').value = event.extendedProps.description || '';
            document.getElementById('startTime').value = formatDateTime(event.start);
            document.getElementById('endTime').value = formatDateTime(event.end);
            
            if(event.extendedProps.isRecurring) {
                document.getElementById('isRecurring').checked = true;
                document.getElementById('recurringSection').style.display = 'block';
                document.getElementById('recurrencePattern').value = event.extendedProps.recurrencePattern || 'daily';
            }
            
            $('#appointmentModal').modal('show');
        }

        function saveAppointment() {
            const title = document.getElementById('title').value;
            const description = document.getElementById('description').value;
            const startTime = new Date(document.getElementById('startTime').value);
            const endTime = new Date(document.getElementById('endTime').value);
            const categoryId = document.getElementById('categoryId').value || null;
            const isRecurring = document.getElementById('isRecurring').checked;
            const recurrencePattern = isRecurring ? document.getElementById('recurrencePattern').value : null;
            const recurrenceEndDate = isRecurring ? document.getElementById('recurrenceEndDate').value || null : null;

            const data = {
                title: title,
                description: description,
                startTime: startTime,
                endTime: endTime,
                categoryId: categoryId ? parseInt(categoryId) : null,
                isRecurring: isRecurring,
                recurrencePattern: recurrencePattern,
                recurrenceEndDate: recurrenceEndDate
            };

            const url = currentEditingId ? `/Calendar/UpdateAppointment/${currentEditingId}` : '/Calendar/CreateAppointment';
            const method = currentEditingId ? 'PUT' : 'POST';

            fetch(url, {
                method: method,
                headers: {
                    'Content-Type': 'application/json',
                    'X-CSRF-TOKEN': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                },
                body: JSON.stringify(data)
            })
            .then(response => {
                if(!response.ok) throw new Error('Network response was not ok');
                return response.json();
            })
            .then(data => {
                $('#appointmentModal').modal('hide');
                location.reload();
            })
            .catch(error => {
                alert('Error saving appointment: ' + error);
                console.error('Error:', error);
            });
        }

        function deleteAppointment(id) {
            fetch(`/Calendar/DeleteAppointment/${id}`, {
                method: 'DELETE',
                headers: {
                    'X-CSRF-TOKEN': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                }
            })
            .then(response => {
                if(!response.ok) throw new Error('Network response was not ok');
                return response.json();
            })
            .then(data => {
                $('#appointmentModal').modal('hide');
                location.reload();
            })
            .catch(error => {
                alert('Error deleting appointment: ' + error);
                console.error('Error:', error);
            });
        }
    </script>
}
