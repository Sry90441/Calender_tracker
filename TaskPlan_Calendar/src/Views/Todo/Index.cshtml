@using taskplan_calendar.Models
@model List<Todo>

@{
    ViewData["Title"] = "To-Do Lists";
    Layout = "~/Views/Shared/_MenuLayout.cshtml";
}

<div class="topbar d-flex justify-content-between align-items-center">
    <div>
        <h4 class="mb-0">To-Do Lists</h4>
    </div>
    <div>
        <button class="btn btn-primary btn-sm" id="addTodoBtn">
            + Add To-Do
        </button>
    </div>
</div>

<div class="main-content">
    <div id="todoContainer" class="todo-container">
        @if (Model != null && Model.Count > 0)
        {
            <div class="row">
                @foreach (var todo in Model)
                {
                    <div class="col-md-6 mb-3">
                        <div class="card">
                            <div class="card-body">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="todo-@todo.Id" 
                                           @(todo.IsDone ? "checked" : "") disabled>
                                    <label class="form-check-label @(todo.IsDone ? "text-decoration-line-through text-muted" : "")" 
                                           for="todo-@todo.Id">
                                        @todo.Title
                                    </label>
                                </div>
                                @if (!string.IsNullOrEmpty(todo.Description))
                                {
                                    <p class="text-muted small mt-2">@todo.Description</p>
                                }
                                @if (todo.DueDate.HasValue)
                                {
                                    <p class="text-muted small">
                                        Due: @todo.DueDate.Value.ToString("MMM dd, yyyy")
                                    </p>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center text-muted mt-5">
                <p>No to-dos yet. Create your first one!</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('addTodoBtn')?.addEventListener('click', function() {
            alert('Add to-do functionality - coming soon');
        });
    </script>
}
