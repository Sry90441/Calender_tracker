@using taskplan_calendar.Models
@{
    ViewData["Title"] = "To-Do Lists";
    Layout = "~/Views/Shared/_MenuLayout.cshtml";
    var todoLists = ViewBag.TodoLists as List<TodoList>;
}

<style>
    .priority-1 { border-left: 4px solid #28a745; }
    .priority-2 { border-left: 4px solid #007bff; }
    .priority-3 { border-left: 4px solid #ffc107; }
    .priority-4 { border-left: 4px solid #dc3545; }

    .todo-item {
        transition: all 0.2s ease;
        cursor: pointer;
    }

    .todo-item:hover {
        box-shadow: 0 4px 8px rgba(0,0,0,0.1);
    }

    .todo-item.done {
        opacity: 0.6;
    }

    .todo-item.done .todo-title {
        text-decoration: line-through;
        color: #6c757d;
    }

    .list-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 15px;
        border-radius: 8px;
        margin-bottom: 15px;
    }

    .priority-badge {
        display: inline-block;
        width: 8px;
        height: 8px;
        border-radius: 50%;
        margin-right: 8px;
    }
</style>

<div class="topbar d-flex justify-content-between align-items-center">
    <div>
        <h4 class="mb-0">To-Do Lists</h4>
    </div>
    <div>
        <button class="btn btn-primary btn-sm" id="addTodoBtn">
            + New Todo
        </button>
        <button class="btn btn-outline-secondary btn-sm" id="newListBtn">
            + New List
        </button>
    </div>
</div>

<div class="main-content">
    @if (todoLists != null && todoLists.Any())
    {
        @foreach (var list in todoLists)
        {
            <div class="mb-4">
                <div class="list-header d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="mb-0">@list.Name</h5>
                        @if (!string.IsNullOrEmpty(list.Description))
                        {
                            <small>@list.Description</small>
                        }
                    </div>
                    <div>
                        <span class="badge badge-light">@list.Todos.Count items</span>
                    </div>
                </div>

                @if (list.Todos.Any())
                {
                    <div class="row">
                        @foreach (var todo in list.Todos.OrderByDescending(t => t.Priority).ThenBy(t => t.DueDate))
                        {
                            var priorityClass = $"priority-{todo.Priority}";
                            var priorityColor = todo.Priority switch
                            {
                                1 => "#28a745",
                                2 => "#007bff",
                                3 => "#ffc107",
                                4 => "#dc3545",
                                _ => "#6c757d"
                            };

                            <div class="col-md-6 col-lg-4 mb-3">
                                <div class="card todo-item @(todo.IsDone ? "done" : "") @priorityClass">
                                    <div class="card-body">
                                        <div class="d-flex align-items-start gap-2">
                                            <input type="checkbox" class="form-check-input mt-1 todo-toggle" data-todo-id="@todo.Id" @(todo.IsDone ? "checked" : "")>
                                            <div class="flex-grow-1">
                                                <h6 class="card-title todo-title mb-1">@todo.Title</h6>
                                                @if (!string.IsNullOrEmpty(todo.Description))
                                                {
                                                    <p class="card-text text-muted small mb-2">@todo.Description</p>
                                                }
                                                <div class="d-flex flex-wrap gap-2 align-items-center mb-2">
                                                    <span class="priority-badge" style="background-color: @priorityColor;" title="Priority @todo.Priority"></span>
                                                    @if (todo.Category != null)
                                                    {
                                                        <span class="badge" style="background-color: @(todo.Category.ColorHex ?? "#6c757d");">@todo.Category.Name</span>
                                                    }
                                                </div>
                                                @if (todo.DueDate.HasValue)
                                                {
                                                    <small class="text-muted">
                                                        Due: @todo.DueDate.Value.ToString("MMM dd, yyyy")
                                                    </small>
                                                }
                                                @if (todo.IsRecurring)
                                                {
                                                    <br>
                                                    <small class="text-info">🔄 @todo.RecurrencePattern</small>
                                                }
                                            </div>
                                            <div>
                                                <button class="btn btn-sm btn-outline-primary edit-todo-btn" data-todo-id="@todo.Id" title="Edit">✎</button>
                                                <button class="btn btn-sm btn-outline-danger delete-todo-btn" data-todo-id="@todo.Id" title="Delete">✕</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center text-muted py-4">
                        <p>No todos in this list yet</p>
                    </div>
                }
            </div>
        }
    }
    else
    {
        <div class="text-center text-muted mt-5">
            <p>No todos yet. Create your first one!</p>
        </div>
    }
</div>

<!-- Todo Modal -->
<div class="modal fade" id="todoModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="todoModalTitle">New Todo</h5>
                <button type="button" class="close" data-dismiss="modal">
                    <span>&times;</span>
                </button>
            </div>
            <form id="todoForm">
                <div class="modal-body">
                    <div class="form-group">
                        <label for="todoTitle">Title *</label>
                        <input type="text" class="form-control" id="todoTitle" name="title" required>
                    </div>
                    <div class="form-group">
                        <label for="todoDescription">Description</label>
                        <textarea class="form-control" id="todoDescription" name="description" rows="3"></textarea>
                    </div>
                    <div class="form-row">
                        <div class="form-group col-md-6">
                            <label for="todoPriority">Priority</label>
                            <select class="form-control" id="todoPriority" name="priority">
                                <option value="1">Low</option>
                                <option value="2" selected>Medium</option>
                                <option value="3">High</option>
                                <option value="4">Critical</option>
                            </select>
                        </div>
                        <div class="form-group col-md-6">
                            <label for="todoDueDate">Due Date</label>
                            <input type="date" class="form-control" id="todoDueDate" name="dueDate">
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="todoCategoryId">Category</label>
                        <select class="form-control" id="todoCategoryId" name="categoryId">
                            <option value="">No Category</option>
                        </select>
                    </div>
                    <div class="form-check">
                        <input type="checkbox" class="form-check-input" id="todoIsRecurring" name="isRecurring">
                        <label class="form-check-label" for="todoIsRecurring">
                            Recurring
                        </label>
                    </div>
                    <div id="recurringSection" style="display: none; margin-top: 15px; padding: 15px; border-left: 3px solid #007bff;">
                        <div class="form-group">
                            <label for="todoRecurrencePattern">Pattern *</label>
                            <select class="form-control" id="todoRecurrencePattern" name="recurrencePattern">
                                <option value="daily">Daily</option>
                                <option value="weekly">Weekly</option>
                                <option value="monthly">Monthly</option>
                                <option value="yearly">Yearly</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label for="todoRecurrenceEndDate">End Date (leave empty for no end date)</label>
                            <input type="date" class="form-control" id="todoRecurrenceEndDate" name="recurrenceEndDate">
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-danger" id="deleteTodoBtn" style="display: none;">Delete</button>
                    <button type="submit" class="btn btn-primary">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let currentEditingTodoId = null;

        document.addEventListener('DOMContentLoaded', function() {
            // Toggle todo completion
            document.querySelectorAll('.todo-toggle').forEach(checkbox => {
                checkbox.addEventListener('change', function() {
                    const todoId = this.dataset.todoId;
                    toggleTodo(todoId);
                });
            });

            // Edit todo button
            document.querySelectorAll('.edit-todo-btn').forEach(btn => {
                btn.addEventListener('click', function() {
                    const todoId = this.dataset.todoId;
                    openEditTodoModal(todoId);
                });
            });

            // Delete todo button
            document.querySelectorAll('.delete-todo-btn').forEach(btn => {
                btn.addEventListener('click', function() {
                    const todoId = this.dataset.todoId;
                    if(confirm('Are you sure you want to delete this todo?')) {
                        deleteTodo(todoId);
                    }
                });
            });

            // Form submission
            document.getElementById('todoForm').addEventListener('submit', function(e) {
                e.preventDefault();
                saveTodo();
            });

            // Recurring checkbox toggle
            document.getElementById('todoIsRecurring').addEventListener('change', function() {
                document.getElementById('recurringSection').style.display = this.checked ? 'block' : 'none';
            });

            // Add todo button
            document.getElementById('addTodoBtn').addEventListener('click', function() {
                openAddTodoModal();
            });

            // New list button
            document.getElementById('newListBtn').addEventListener('click', function() {
                alert('New list functionality - coming soon!');
            });
        });

        function openAddTodoModal() {
            currentEditingTodoId = null;
            document.getElementById('todoForm').reset();
            document.getElementById('todoModalTitle').textContent = 'New Todo';
            document.getElementById('deleteTodoBtn').style.display = 'none';
            document.getElementById('recurringSection').style.display = 'none';
            $('#todoModal').modal('show');
        }

        function openEditTodoModal(todoId) {
            currentEditingTodoId = todoId;
            document.getElementById('todoModalTitle').textContent = 'Edit Todo';
            document.getElementById('deleteTodoBtn').style.display = 'block';
            // TODO: Fetch todo data and populate form
            $('#todoModal').modal('show');
        }

        function saveTodo() {
            const title = document.getElementById('todoTitle').value;
            const description = document.getElementById('todoDescription').value;
            const priority = parseInt(document.getElementById('todoPriority').value);
            const dueDate = document.getElementById('todoDueDate').value || null;
            const categoryId = document.getElementById('todoCategoryId').value || null;
            const isRecurring = document.getElementById('todoIsRecurring').checked;
            const recurrencePattern = isRecurring ? document.getElementById('todoRecurrencePattern').value : null;
            const recurrenceEndDate = isRecurring ? document.getElementById('todoRecurrenceEndDate').value || null : null;

            const data = {
                title: title,
                description: description,
                priority: priority,
                dueDate: dueDate ? new Date(dueDate) : null,
                categoryId: categoryId ? parseInt(categoryId) : null,
                isRecurring: isRecurring,
                recurrencePattern: recurrencePattern,
                recurrenceEndDate: recurrenceEndDate
            };

            const url = currentEditingTodoId ? `/Todo/UpdateTodo/${currentEditingTodoId}` : '/Todo/CreateTodo';
            const method = currentEditingTodoId ? 'PUT' : 'POST';

            fetch(url, {
                method: method,
                headers: {
                    'Content-Type': 'application/json',
                    'X-CSRF-TOKEN': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                },
                body: JSON.stringify(data)
            })
            .then(response => {
                if(!response.ok) throw new Error('Network response was not ok');
                return response.json();
            })
            .then(data => {
                $('#todoModal').modal('hide');
                location.reload();
            })
            .catch(error => {
                alert('Error saving todo: ' + error);
                console.error('Error:', error);
            });
        }

        function toggleTodo(todoId) {
            fetch(`/Todo/ToggleTodo/${todoId}`, {
                method: 'PUT',
                headers: {
                    'X-CSRF-TOKEN': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                }
            })
            .then(response => response.json())
            .then(data => {
                location.reload();
            })
            .catch(error => console.error('Error:', error));
        }

        function deleteTodo(todoId) {
            fetch(`/Todo/DeleteTodo/${todoId}`, {
                method: 'DELETE',
                headers: {
                    'X-CSRF-TOKEN': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                }
            })
            .then(response => response.json())
            .then(data => {
                $('#todoModal').modal('hide');
                location.reload();
            })
            .catch(error => console.error('Error:', error));
        }
    </script>
}
