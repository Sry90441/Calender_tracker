@using taskplan_calendar.Models
@model List<Category>

@{
    ViewData["Title"] = "Categories";
    Layout = "~/Views/Shared/_MenuLayout.cshtml";
}

<div class="topbar d-flex justify-content-between align-items-center">
    <div>
        <h4 class="mb-0">Categories</h4>
    </div>
    <div>
        <button class="btn btn-primary btn-sm" id="addCategoryBtn">
            + Add Category
        </button>
    </div>
</div>

<div class="main-content">
    <div id="categoryContainer" class="category-container">
        @if (Model != null && Model.Count > 0)
        {
            <div class="row">
                @foreach (var category in Model)
                {
                    <div class="col-md-6 mb-3">
                        <div class="card">
                            <div class="card-body">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="rounded-circle" style="width: 50px; height: 50px; background-color: @category.ColorHex;"></div>
                                    <div class="flex-grow-1">
                                        <h5 class="card-title mb-0">@category.Name</h5>
                                        @if (!string.IsNullOrEmpty(category.Description))
                                        {
                                            <p class="text-muted small mb-0">@category.Description</p>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center text-muted mt-5">
                <p>No categories yet. Create your first one!</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('addCategoryBtn')?.addEventListener('click', function() {
            alert('Add category functionality - coming soon');
        });
    </script>
}
